# Connection string PostgreSQL (locale Docker o cloud Neon)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# In produzione (Neon) aggiungere ?sslmode=require
DATABASE_URL=

# Server
PORT=5000
NODE_ENV=development   # production | staging | development

# JWT — generare con: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=replace_with_64_byte_hex
JWT_EXPIRES_IN=7d

# CORS — lista di origini frontend separate da virgola
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Path cartella dati OMI (solo development — non necessario in cloud)
DATI_OMI_PATH=/path/to/DATI_OMI
