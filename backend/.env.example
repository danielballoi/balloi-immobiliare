# Database MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=omi
DB_PORT=3306

# Server
PORT=5000
NODE_ENV=development   # production | staging | development

# JWT — generare con: node -e "require('crypto').randomBytes(64).toString('hex')|Write-Host"
JWT_SECRET=replace_with_a_strong_random_64_byte_hex_secret
JWT_EXPIRES_IN=7d

# CORS — lista di origini frontend separate da virgola
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Path cartella dati OMI (solo development)
DATI_OMI_PATH=C:/path/to/DATI_OMI
